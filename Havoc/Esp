local RotationAngle, Tick = -45, tick();

local function cleanWeaponName(name)
    return name:gsub("[%.%?]", " ")
end

local function getNpcContainer()
    for _, child in pairs(Workspace:GetChildren()) do
        if child:IsA("Model") and child:GetAttribute("npcCount") ~= nil then
            return child
        end
    end
    return nil
end

local npcContainer = getNpcContainer()
if not npcContainer then
    return ESP
end

local Functions = {}
do
    function Functions:Create(Class, Properties)
        local _Instance = typeof(Class) == 'string' and Instance.new(Class) or Class
        for Property, Value in pairs(Properties) do
            _Instance[Property] = Value
        end
        return _Instance;
    end
    
    function Functions:FadeOutOnDist(element, distance)
        local transparency = math.max(0.1, 1 - (distance / ESP.MaxDistance))
        if element:IsA("TextLabel") then
            element.TextTransparency = 1 - transparency
        elseif element:IsA("ImageLabel") then
            element.ImageTransparency = 1 - transparency
        elseif element:IsA("UIStroke") then
            element.Transparency = 1 - transparency
        elseif element:IsA("Frame") then
            element.BackgroundTransparency = 1 - transparency
        elseif element:IsA("Highlight") then
            element.FillTransparency = 1 - transparency
            element.OutlineTransparency = 1 - transparency
        end
    end  
end;

local guiName = "ESPHolder"
if CoreGui:FindFirstChild(guiName) then
    CoreGui[guiName]:Destroy()
end

local ScreenGui = Functions:Create("ScreenGui", {
    Parent = CoreGui,
    Name = guiName,
});

local ESPFunction = function(char)
    local containerName = char.Name
    if ScreenGui:FindFirstChild(containerName) then
        ScreenGui[containerName]:Destroy()
    end

    local isNPC = char:GetAttribute("DefaultName") ~= nil
    if isNPC and not ESP.ShowNpc then
        return
    end
    
    local playerObj = not isNPC and Players:GetPlayerFromCharacter(char) or nil

    local container = Functions:Create("Frame", {
        Parent = ScreenGui,
        Name = containerName,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Position = UDim2.new(0, 0, 0, 0),
    })

    local Name = Functions:Create("TextLabel", {Parent = container, Position = UDim2.new(0.5, 0, 0, -11), Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(0, 0, 0), RichText = true})
    local Distance = Functions:Create("TextLabel", {Parent = container, Position = UDim2.new(0.5, 0, 0, 11), Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(0, 0, 0), RichText = true})
    local Weapon = Functions:Create("TextLabel", {Parent = container, Position = UDim2.new(0.5, 0, 0, 31), Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(0, 0, 0), RichText = true})
    local Box = Functions:Create("Frame", {Parent = container, BackgroundColor3 = Color3.fromRGB(0, 0, 0), BackgroundTransparency = 1, BorderSizePixel = 0})
    local FillGradient = Functions:Create("UIGradient", {Parent = Box, Enabled = false, Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Filled.GradientRGB1), ColorSequenceKeypoint.new(1, ESP.Drawing.Filled.GradientRGB2)}})
    local OutlineStroke = Functions:Create("UIStroke", {Parent = Box, Enabled = true, Transparency = 0, Color = Color3.fromRGB(255, 255, 255), Thickness = 1, LineJoinMode = Enum.LineJoinMode.Miter})
    local OutlineGradient = Functions:Create("UIGradient", {Parent = OutlineStroke, Enabled = false, Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(255,255,255))}})
    local Healthbar = Functions:Create("Frame", {Parent = container, BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 0})
    local BehindHealthbar = Functions:Create("Frame", {Parent = container, ZIndex = -1, BackgroundColor3 = Color3.fromRGB(0, 0, 0), BackgroundTransparency = 0})
    local HealthbarGradient = Functions:Create("UIGradient", {Parent = Healthbar, Enabled = false, Rotation = -90, Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(255,255,255))}})
    local HealthText = Functions:Create("TextLabel", {Parent = container, Position = UDim2.new(0.5, 0, 0, 31), Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(0, 0, 0)})
    local Chams = Functions:Create("Highlight", {Parent = container, FillTransparency = 1, OutlineTransparency = 1, OutlineColor = Color3.fromRGB(119, 120, 255), DepthMode = "AlwaysOnTop"})
    local LeftTop = Functions:Create("Frame", {Parent = container, BackgroundColor3 = ESP.Drawing.Corner.Color, BackgroundTransparency = ESP.Drawing.Corner.Transparency, Position = UDim2.new(0, 0, 0, 0)})
    local LeftSide = Functions:Create("Frame", {Parent = container, BackgroundColor3 = ESP.Drawing.Corner.Color, BackgroundTransparency = ESP.Drawing.Corner.Transparency, Position = UDim2.new(0, 0, 0, 0)})
    local RightTop = Functions:Create("Frame", {Parent = container, BackgroundColor3 = ESP.Drawing.Corner.Color, BackgroundTransparency = ESP.Drawing.Corner.Transparency, Position = UDim2.new(0, 0, 0, 0)})
    local RightSide = Functions:Create("Frame", {Parent = container, BackgroundColor3 = ESP.Drawing.Corner.Color, BackgroundTransparency = ESP.Drawing.Corner.Transparency, Position = UDim2.new(0, 0, 0, 0)})
    local BottomSide = Functions:Create("Frame", {Parent = container, BackgroundColor3 = ESP.Drawing.Corner.Color, BackgroundTransparency = ESP.Drawing.Corner.Transparency, Position = UDim2.new(0, 0, 0, 0)})
    local BottomDown = Functions:Create("Frame", {Parent = container, BackgroundColor3 = ESP.Drawing.Corner.Color, BackgroundTransparency = ESP.Drawing.Corner.Transparency, Position = UDim2.new(0, 0, 0, 0)})
    local BottomRightSide = Functions:Create("Frame", {Parent = container, BackgroundColor3 = ESP.Drawing.Corner.Color, BackgroundTransparency = ESP.Drawing.Corner.Transparency, Position = UDim2.new(0, 0, 0, 0)})
    local BottomRightDown = Functions:Create("Frame", {Parent = container, BackgroundColor3 = ESP.Drawing.Corner.Color, BackgroundTransparency = ESP.Drawing.Corner.Transparency, Position = UDim2.new(0, 0, 0, 0)})
    local Flag1 = Functions:Create("TextLabel", {Parent = container, Position = UDim2.new(1, 0, 0, 0), Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(0, 0, 0)})
    local Flag2 = Functions:Create("TextLabel", {Parent = container, Position = UDim2.new(1, 0, 0, 0), Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(0, 0, 0)})

    local Updater = function()
        local Connection;
        local destroyed = false
        local function DestroyESP()
            if destroyed then return end
            destroyed = true
            Connection:Disconnect()
            container:Destroy()
        end
        local function HideESP()
            Box.Visible = false;
            Name.Visible = false;
            Distance.Visible = false;
            Weapon.Visible = false;
            Healthbar.Visible = false;
            BehindHealthbar.Visible = false;
            HealthText.Visible = false;
            LeftTop.Visible = false;
            LeftSide.Visible = false;
            BottomSide.Visible = false;
            BottomDown.Visible = false;
            RightTop.Visible = false;
            RightSide.Visible = false;
            BottomRightSide.Visible = false;
            BottomRightDown.Visible = false;
            Flag1.Visible = false;
            Chams.Enabled = false;
            Flag2.Visible = false;
        end
        Connection = Euphoria.RunService.RenderStepped:Connect(function()
            if destroyed then return end
            if not char or not char.Parent then
                DestroyESP()
                return
            end
            local HRP = char:FindFirstChild("HumanoidRootPart")
            local Humanoid = char:FindFirstChild("Humanoid")
            if not HRP or not Humanoid then
                HideESP()
                return
            end
            local Pos, OnScreen = Cam:WorldToScreenPoint(HRP.Position)
            local Dist = (Cam.CFrame.Position - HRP.Position).Magnitude / 3.5714285714
            
            if OnScreen and Dist <= ESP.MaxDistance then
                local fov = Cam.FieldOfView
                local fovScale = math.tan(math.rad(70/2)) / math.tan(math.rad(fov/2))
                local Size = HRP.Size.Y
                local scaleFactor = (Size * Cam.ViewportSize.Y) / (Pos.Z * 2) * fovScale
                local w = 3 * scaleFactor
                local h = 4.5 * scaleFactor

                if ESP.FadeOut.OnDistance then
                    Functions:FadeOutOnDist(Box, Dist)
                    Functions:FadeOutOnDist(OutlineStroke, Dist)
                    Functions:FadeOutOnDist(Name, Dist)
                    Functions:FadeOutOnDist(Distance, Dist)
                    Functions:FadeOutOnDist(Weapon, Dist)
                    Functions:FadeOutOnDist(Healthbar, Dist)
                    Functions:FadeOutOnDist(BehindHealthbar, Dist)
                    Functions:FadeOutOnDist(HealthText, Dist)
                    Functions:FadeOutOnDist(LeftTop, Dist)
                    Functions:FadeOutOnDist(LeftSide, Dist)
                    Functions:FadeOutOnDist(BottomSide, Dist)
                    Functions:FadeOutOnDist(BottomDown, Dist)
                    Functions:FadeOutOnDist(RightTop, Dist)
                    Functions:FadeOutOnDist(RightSide, Dist)
                    Functions:FadeOutOnDist(BottomRightSide, Dist)
                    Functions:FadeOutOnDist(BottomRightDown, Dist)
                    Functions:FadeOutOnDist(Chams, Dist)
                    Functions:FadeOutOnDist(Flag1, Dist)
                    Functions:FadeOutOnDist(Flag2, Dist)
                end

                local show = false
                if isNPC then
                    show = ESP.ShowNpc
                elseif not ESP.TeamCheck then
                    show = true
                else
                    if playerObj and playerObj ~= lplayer then
                        local localParty = lplayer:GetAttribute("partyId")
                        local targetParty = playerObj:GetAttribute("partyId")
                        if localParty and targetParty and localParty == targetParty then
                            show = false
                        else
                            show = true
                        end
                    else
                        show = false
                    end
                end

                if show then
                    Chams.Adornee = char
                    Chams.Enabled = ESP.Drawing.Chams.Enabled
                    Chams.FillColor = ESP.Drawing.Chams.FillRGB
                    Chams.OutlineColor = ESP.Drawing.Chams.OutlineRGB
                    if ESP.Drawing.Chams.Thermal then
                        local breathe_effect = math.atan(math.sin(tick() * 2)) * 2 / math.pi
                        Chams.FillTransparency = ESP.Drawing.Chams.Fill_Transparency * breathe_effect * 0.01
                        Chams.OutlineTransparency = ESP.Drawing.Chams.Outline_Transparency * breathe_effect * 0.01
                    else
                        Chams.FillTransparency = 1
                        Chams.OutlineTransparency = 0
                    end
                    if ESP.Drawing.Chams.VisibleCheck then
                        Chams.DepthMode = "Occluded"
                    else
                        Chams.DepthMode = "AlwaysOnTop"
                    end

                    local cornerLen = ESP.Drawing.Corner.Length
                    LeftTop.Visible = ESP.Drawing.Corner.Enabled
                    LeftTop.Position = UDim2.new(0, Pos.X - w / 2, 0, Pos.Y - h / 2)
                    LeftTop.Size = UDim2.new(0, w / cornerLen, 0, 1)
                    LeftTop.BackgroundColor3 = ESP.Drawing.Corner.Color
                    LeftTop.BackgroundTransparency = ESP.Drawing.Corner.Transparency
                    
                    LeftSide.Visible = ESP.Drawing.Corner.Enabled
                    LeftSide.Position = UDim2.new(0, Pos.X - w / 2, 0, Pos.Y - h / 2)
                    LeftSide.Size = UDim2.new(0, 1, 0, h / cornerLen)
                    LeftSide.BackgroundColor3 = ESP.Drawing.Corner.Color
                    LeftSide.BackgroundTransparency = ESP.Drawing.Corner.Transparency
                    
                    BottomSide.Visible = ESP.Drawing.Corner.Enabled
                    BottomSide.Position = UDim2.new(0, Pos.X - w / 2, 0, Pos.Y + h / 2)
                    BottomSide.Size = UDim2.new(0, 1, 0, h / cornerLen)
                    BottomSide.AnchorPoint = Vector2.new(0, 5)
                    BottomSide.BackgroundColor3 = ESP.Drawing.Corner.Color
                    BottomSide.BackgroundTransparency = ESP.Drawing.Corner.Transparency
                    
                    BottomDown.Visible = ESP.Drawing.Corner.Enabled
                    BottomDown.Position = UDim2.new(0, Pos.X - w / 2, 0, Pos.Y + h / 2)
                    BottomDown.Size = UDim2.new(0, w / cornerLen, 0, 1)
                    BottomDown.AnchorPoint = Vector2.new(0, 1)
                    BottomDown.BackgroundColor3 = ESP.Drawing.Corner.Color
                    BottomDown.BackgroundTransparency = ESP.Drawing.Corner.Transparency
                    
                    RightTop.Visible = ESP.Drawing.Corner.Enabled
                    RightTop.Position = UDim2.new(0, Pos.X + w / 2, 0, Pos.Y - h / 2)
                    RightTop.Size = UDim2.new(0, w / cornerLen, 0, 1)
                    RightTop.AnchorPoint = Vector2.new(1, 0)
                    RightTop.BackgroundColor3 = ESP.Drawing.Corner.Color
                    RightTop.BackgroundTransparency = ESP.Drawing.Corner.Transparency
                    
                    RightSide.Visible = ESP.Drawing.Corner.Enabled
                    RightSide.Position = UDim2.new(0, Pos.X + w / 2 - 1, 0, Pos.Y - h / 2)
                    RightSide.Size = UDim2.new(0, 1, 0, h / cornerLen)
                    RightSide.AnchorPoint = Vector2.new(0, 0)
                    RightSide.BackgroundColor3 = ESP.Drawing.Corner.Color
                    RightSide.BackgroundTransparency = ESP.Drawing.Corner.Transparency
                    
                    BottomRightSide.Visible = ESP.Drawing.Corner.Enabled
                    BottomRightSide.Position = UDim2.new(0, Pos.X + w / 2, 0, Pos.Y + h / 2)
                    BottomRightSide.Size = UDim2.new(0, 1, 0, h / cornerLen)
                    BottomRightSide.AnchorPoint = Vector2.new(1, 1)
                    BottomRightSide.BackgroundColor3 = ESP.Drawing.Corner.Color
                    BottomRightSide.BackgroundTransparency = ESP.Drawing.Corner.Transparency
                    
                    BottomRightDown.Visible = ESP.Drawing.Corner.Enabled
                    BottomRightDown.Position = UDim2.new(0, Pos.X + w / 2, 0, Pos.Y + h / 2)
                    BottomRightDown.Size = UDim2.new(0, w / cornerLen, 0, 1)
                    BottomRightDown.AnchorPoint = Vector2.new(1, 1)
                    BottomRightDown.BackgroundColor3 = ESP.Drawing.Corner.Color
                    BottomRightDown.BackgroundTransparency = ESP.Drawing.Corner.Transparency

                    Box.Position = UDim2.new(0, Pos.X - w / 2, 0, Pos.Y - h / 2)
                    Box.Size = UDim2.new(0, w, 0, h)
                    Box.Visible = ESP.Drawing.Box.Enabled

                    if ESP.Drawing.Filled.Enabled then
                        Box.BackgroundColor3 = ESP.Drawing.Filled.Color
                        Box.BackgroundTransparency = ESP.Drawing.Filled.Transparency
                        Box.BorderSizePixel = 0
                        FillGradient.Enabled = ESP.Drawing.Filled.Gradient
                        if ESP.Drawing.Filled.Gradient then
                            FillGradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Filled.GradientRGB1), ColorSequenceKeypoint.new(1, ESP.Drawing.Filled.GradientRGB2)}
                            FillGradient.Rotation = ESP.Drawing.Filled.Animate and RotationAngle or -45
                        end
                    else
                        Box.BackgroundTransparency = 1
                        FillGradient.Enabled = false
                    end

                    OutlineStroke.Enabled = ESP.Drawing.Box.Enabled
                    OutlineStroke.Color = ESP.Drawing.Box.Color
                    OutlineStroke.Transparency = ESP.Drawing.Box.Transparency
                    OutlineStroke.Thickness = ESP.Drawing.Box.Thickness

                    OutlineGradient.Enabled = ESP.Drawing.Box.Gradient
                    if ESP.Drawing.Box.Gradient then
                        OutlineGradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Box.GradientRGB1), ColorSequenceKeypoint.new(1, ESP.Drawing.Box.GradientRGB2)}
                        if ESP.Drawing.Box.Animate then
                            RotationAngle = RotationAngle + (tick() - Tick) * ESP.Drawing.Box.RotationSpeed * math.cos(math.pi / 4 * tick() - math.pi / 2)
                            OutlineGradient.Rotation = RotationAngle
                        else
                            OutlineGradient.Rotation = -45
                        end
                    end

                    Tick = tick()

                    local health = Humanoid.Health / Humanoid.MaxHealth
                    Healthbar.Visible = ESP.Drawing.Healthbar.Enabled
                    Healthbar.Position = UDim2.new(0, Pos.X - w / 2 - 6, 0, Pos.Y - h / 2 + h * (1 - health))  
                    Healthbar.Size = UDim2.new(0, ESP.Drawing.Healthbar.Width, 0, h * health)  
                    
                    BehindHealthbar.Visible = ESP.Drawing.Healthbar.Enabled
                    BehindHealthbar.Position = UDim2.new(0, Pos.X - w / 2 - 6, 0, Pos.Y - h / 2)  
                    BehindHealthbar.Size = UDim2.new(0, ESP.Drawing.Healthbar.Width, 0, h)

                    HealthbarGradient.Enabled = ESP.Drawing.Healthbar.Gradient
                    if ESP.Drawing.Healthbar.Gradient then
                        HealthbarGradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Healthbar.GradientRGB1), ColorSequenceKeypoint.new(0.5, ESP.Drawing.Healthbar.GradientRGB2), ColorSequenceKeypoint.new(1, ESP.Drawing.Healthbar.GradientRGB3)}
                    end
                    
                    if ESP.Drawing.Healthbar.HealthText then
                        local healthPercentage = math.floor(Humanoid.Health / Humanoid.MaxHealth * 100)
                        HealthText.Position = UDim2.new(0, Pos.X - w / 2 - 6, 0, Pos.Y - h / 2 + h * (1 - healthPercentage / 100) + 3)
                        HealthText.Text = tostring(healthPercentage)
                        HealthText.Visible = Humanoid.Health < Humanoid.MaxHealth
                        if ESP.Drawing.Healthbar.Lerp then
                            local color = health >= 0.75 and Color3.fromRGB(0, 255, 0) or health >= 0.5 and Color3.fromRGB(255, 255, 0) or health >= 0.25 and Color3.fromRGB(255, 170, 0) or Color3.fromRGB(255, 0, 0)
                            HealthText.TextColor3 = color
                        else
                            HealthText.TextColor3 = ESP.Drawing.Healthbar.HealthTextRGB
                        end
                    else
                        HealthText.Visible = false
                    end

                    Name.Visible = ESP.Drawing.Names.Enabled
                    local suffix = isNPC and " [Npc]" or " [Player]"
                    Name.Text = char.Name .. suffix
                    Name.Position = UDim2.new(0, Pos.X, 0, Pos.Y - h / 2 - 9)

                    if ESP.Drawing.Distances.Enabled then
                        if ESP.Drawing.Distances.Position == "Bottom" then
                            Weapon.Position = UDim2.new(0, Pos.X, 0, Pos.Y + h / 2 + 7)
                            Weapon.Visible = ESP.Drawing.Weapons.Enabled
                            local tool = char:FindFirstChildOfClass("Tool")
                            Weapon.Text = tool and cleanWeaponName(tool.Name) or "none"
                            
                            Distance.Position = UDim2.new(0, Pos.X, 0, Pos.Y + h / 2 + 18)
                            Distance.Text = string.format("%d meters", math.floor(Dist))
                            Distance.Visible = true
                        elseif ESP.Drawing.Distances.Position == "Text" then
                            Weapon.Position = UDim2.new(0, Pos.X, 0, Pos.Y + h / 2 + 8)
                            Weapon.Visible = ESP.Drawing.Weapons.Enabled
                            local tool = char:FindFirstChildOfClass("Tool")
                            Weapon.Text = tool and cleanWeaponName(tool.Name) or "none"
                            
                            Distance.Visible = false
                            Name.Text = string.format("%s%s [%d]", char.Name, suffix, math.floor(Dist))
                            Name.Visible = ESP.Drawing.Names.Enabled
                        end
                    else
                        Weapon.Position = UDim2.new(0, Pos.X, 0, Pos.Y + h / 2 + 8)
                        Weapon.Visible = ESP.Drawing.Weapons.Enabled
                        local tool = char:FindFirstChildOfClass("Tool")
                        Weapon.Text = tool and cleanWeaponName(tool.Name) or "none"
                        Distance.Visible = false
                    end
                else
                    HideESP()
                end
            else
                HideESP()
            end
        end)
    end
    coroutine.wrap(Updater)()
end

for _, child in pairs(npcContainer:GetChildren()) do
    if child:IsA("Model") and child:FindFirstChild("HumanoidRootPart") and child:FindFirstChild("Humanoid") then
        if child ~= lplayer.Character then
            coroutine.wrap(ESPFunction)(child)
        end
    end
end

npcContainer.ChildAdded:Connect(function(child)
    if child:IsA("Model") and child:FindFirstChild("HumanoidRootPart") and child:FindFirstChild("Humanoid") then
        if child ~= lplayer.Character then
            coroutine.wrap(ESPFunction)(child)
        end
    end
end)

return ESP
