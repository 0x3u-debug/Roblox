local function cleanWeaponName(name)
    return name:gsub("[%.%?]", " ")
end

local function getNpcContainer()
    for _, child in pairs(Workspace:GetChildren()) do
        if child:IsA("Model") and child:GetAttribute("npcCount") ~= nil then
            return child
        end
    end
    return nil
end

local npcContainer = getNpcContainer()
if not npcContainer then
    return ESP
end

local Functions = {}
do
    function Functions:Create(Class, Properties)
        local _Instance = typeof(Class) == "string" and Instance.new(Class) or Class
        for Property, Value in pairs(Properties) do
            _Instance[Property] = Value
        end
        return _Instance
    end

    function Functions:FadeOutOnDist(element, distance)
        local alpha = math.clamp(1 - (distance / ESP.MaxDistance), 0.3, 1)
        if element:IsA("TextLabel") then
            element.TextTransparency = 1 - alpha
        elseif element:IsA("ImageLabel") then
            element.ImageTransparency = 1 - alpha
        elseif element:IsA("UIStroke") then
            element.Transparency = 1 - alpha
        elseif element:IsA("Frame") then
            element.BackgroundTransparency = 1 - alpha
        elseif element:IsA("Highlight") then
            element.FillTransparency = 1 - alpha
            element.OutlineTransparency = 1 - alpha
        end
    end
end

local function removeESP(char)
    if cache[char] then
        if cache[char].BBG then cache[char].BBG:Destroy() end
        cache[char] = nil
    end
end

local function applyESP(char)
    if cache[char] then return end

    local isNPC = char:GetAttribute("AI") ~= nil
    local playerObj = not isNPC and Players:GetPlayerFromCharacter(char) or nil

    local BBG = Functions:Create("BillboardGui", {
        Parent = CoreGui,
        Name = char.Name .. "_BBG",
        Size = UDim2.new(0, 200, 0, 200),
        AlwaysOnTop = true,
        ResetOnSpawn = false,
        ClipsDescendants = false,
    })

    local MainFrame = Functions:Create("Frame", {
        Parent = BBG,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
    })

    local Name = Functions:Create("TextLabel", {Parent = MainFrame, Size = UDim2.new(0, 200, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, Text = "", TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(0, 0, 0), RichText = true})
    local Weapon = Functions:Create("TextLabel", {Parent = MainFrame, Size = UDim2.new(0, 200, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, Text = "", TextColor3 = Color3.fromRGB(119, 120, 255), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(0, 0, 0), RichText = true, TextXAlignment = Enum.TextXAlignment.Center})
    local Distance = Functions:Create("TextLabel", {Parent = MainFrame, Size = UDim2.new(0, 200, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, Text = "", TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(0, 0, 0), RichText = true, TextXAlignment = Enum.TextXAlignment.Center})
    local StateLabel = Functions:Create("TextLabel", {Parent = MainFrame, Size = UDim2.new(0, 200, 0, 100), AnchorPoint = Vector2.new(0, 0), BackgroundTransparency = 1, Text = "", Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(0, 0, 0), RichText = true, TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top, TextWrapped = true})
    
    local Box = Functions:Create("Frame", {Parent = MainFrame, BackgroundColor3 = Color3.fromRGB(0, 0, 0), BackgroundTransparency = 1, BorderSizePixel = 0})
    local FillGradient = Functions:Create("UIGradient", {Parent = Box})
    local OutlineStroke = Functions:Create("UIStroke", {Parent = Box, LineJoinMode = Enum.LineJoinMode.Miter})
    local OutlineGradient = Functions:Create("UIGradient", {Parent = OutlineStroke})
    
    local BehindHealthbar = Functions:Create("Frame", {Parent = MainFrame, ZIndex = -1, BackgroundColor3 = Color3.fromRGB(0, 0, 0), BackgroundTransparency = 0, BorderSizePixel = 0})
    local HealthContainer = Functions:Create("Frame", {Parent = MainFrame, BackgroundTransparency = 1, ClipsDescendants = true, BorderSizePixel = 0})
    local Healthbar = Functions:Create("Frame", {Parent = HealthContainer, BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 0, BorderSizePixel = 0})
    local HealthbarGradient = Functions:Create("UIGradient", {Parent = Healthbar, Rotation = -90})
    local HealthText = Functions:Create("TextLabel", {Parent = MainFrame, Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, Text = "", TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(0, 0, 0)})
    local Chams = Functions:Create("Highlight", {Parent = MainFrame, FillTransparency = 1, OutlineTransparency = 0, OutlineColor = Color3.fromRGB(119, 120, 255), DepthMode = "AlwaysOnTop"})

    local LeftTop = Functions:Create("Frame", {Parent = MainFrame, BorderSizePixel = 0})
    local LeftSide = Functions:Create("Frame", {Parent = MainFrame, BorderSizePixel = 0})
    local RightTop = Functions:Create("Frame", {Parent = MainFrame, BorderSizePixel = 0})
    local RightSide = Functions:Create("Frame", {Parent = MainFrame, BorderSizePixel = 0})
    local BottomSide = Functions:Create("Frame", {Parent = MainFrame, BorderSizePixel = 0})
    local BottomDown = Functions:Create("Frame", {Parent = MainFrame, BorderSizePixel = 0})
    local BottomRightSide = Functions:Create("Frame", {Parent = MainFrame, BorderSizePixel = 0})
    local BottomRightDown = Functions:Create("Frame", {Parent = MainFrame, BorderSizePixel = 0})

    cache[char] = {
        BBG = BBG,
        MainFrame = MainFrame,
        Name = Name,
        Weapon = Weapon,
        Distance = Distance,
        StateLabel = StateLabel,
        Box = Box,
        FillGradient = FillGradient,
        OutlineStroke = OutlineStroke,
        OutlineGradient = OutlineGradient,
        HealthContainer = HealthContainer,
        Healthbar = Healthbar,
        BehindHealthbar = BehindHealthbar,
        HealthbarGradient = HealthbarGradient,
        HealthText = HealthText,
        Chams = Chams,
        Corners = {LeftTop, LeftSide, BottomSide, BottomDown, RightTop, RightSide, BottomRightSide, BottomRightDown},
        IsNPC = isNPC,
        PlayerObj = playerObj
    }
end

RunService.RenderStepped:Connect(function()
    if not ESP.Enabled then
        for _, data in pairs(cache) do
            data.MainFrame.Visible = false
            data.Chams.Enabled = false
        end
        return
    end

    local localPos = Cam.CFrame.Position
    local fovRad = math.tan(math.rad(Cam.FieldOfView / 2)) * 2

    for char, data in pairs(cache) do
        if not char:IsDescendantOf(Workspace) then
            removeESP(char)
            continue
        end

        local HRP = char:FindFirstChild("HumanoidRootPart")
        local Humanoid = char:FindFirstChild("Humanoid")

        if not HRP or not Humanoid or not HRP.Parent or not Humanoid.Parent then
            data.MainFrame.Visible = false
            data.Chams.Enabled = false
            continue
        end

        local hrpPos = HRP.Position
        local Pos, OnScreen = Cam:WorldToScreenPoint(hrpPos)
        local Dist = (localPos - hrpPos).Magnitude / 3.5714285714

        if OnScreen and Dist <= ESP.MaxDistance then
            local show = false
            local overrideNameColor = nil

            if data.IsNPC then
                show = ESP.ShowNpc
            else
                if data.PlayerObj and char.Name ~= lplayer.Name then
                    local localParty = lplayer:GetAttribute("partyId")
                    local targetParty = data.PlayerObj:GetAttribute("partyId")
                    local isTeam = localParty and targetParty and localParty == targetParty
                    local isFriend = pcall(function() return lplayer:IsFriendsWith(data.PlayerObj.UserId) end) and lplayer:IsFriendsWith(data.PlayerObj.UserId)

                    if isTeam and ESP.Options.Teamcheck then
                        if ESP.Options.TeamcheckShow then
                            show = true
                            overrideNameColor = ESP.Options.TeamcheckRGB
                        else
                            show = false
                        end
                    elseif isFriend and ESP.Options.Friendcheck then
                        if ESP.Options.FriendcheckShow then
                            show = true
                            overrideNameColor = ESP.Options.FriendcheckRGB
                        else
                            show = false
                        end
                    else
                        show = true
                    end
                else
                    show = false
                end
            end

            if show then
                data.MainFrame.Visible = true
                data.BBG.Adornee = HRP

                -- Fixed scaling formula to prevent sizing from collapsing completely at distance/during ADS
                local factor = 1 / (Pos.Z * fovRad)
                local h = math.clamp(factor * 6000, 45, 1200) -- Increased minimum floor to 45 so elements don't overlap
                local w = h / 1.4

                data.BBG.Size = UDim2.new(0, w * 2, 0, h * 2)

                local midX = w
                local midY = h

                -- Dynamic Color updates every frame
                data.Name.TextSize = ESP.FontSize
                data.Weapon.TextSize = ESP.FontSize
                data.Distance.TextSize = ESP.FontSize
                data.StateLabel.TextSize = ESP.FontSize

                data.FillGradient.Enabled = ESP.Drawing.Filled.Gradient
                data.FillGradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Filled.GradientRGB1), ColorSequenceKeypoint.new(1, ESP.Drawing.Filled.GradientRGB2)}
                
                data.OutlineStroke.Enabled = ESP.Drawing.Box.Enabled
                data.OutlineStroke.Color = ESP.Drawing.Box.Color
                data.OutlineStroke.Transparency = ESP.Drawing.Box.Transparency
                data.OutlineStroke.Thickness = ESP.Drawing.Box.Thickness

                data.OutlineGradient.Enabled = ESP.Drawing.Box.Gradient
                data.OutlineGradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Box.GradientRGB1), ColorSequenceKeypoint.new(1, ESP.Drawing.Box.GradientRGB2)}

                data.HealthbarGradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Healthbar.GradientRGB1), ColorSequenceKeypoint.new(0.5, ESP.Drawing.Healthbar.GradientRGB2), ColorSequenceKeypoint.new(1, ESP.Drawing.Healthbar.GradientRGB3)}

                if ESP.FadeOut.OnDistance then
                    Functions:FadeOutOnDist(data.Box, Dist)
                    Functions:FadeOutOnDist(data.OutlineStroke, Dist)
                    Functions:FadeOutOnDist(data.Name, Dist)
                    Functions:FadeOutOnDist(data.Distance, Dist)
                    Functions:FadeOutOnDist(data.Weapon, Dist)
                    Functions:FadeOutOnDist(data.Healthbar, Dist)
                    Functions:FadeOutOnDist(data.BehindHealthbar, Dist)
                    Functions:FadeOutOnDist(data.HealthText, Dist)
                    Functions:FadeOutOnDist(data.Chams, Dist)
                    Functions:FadeOutOnDist(data.StateLabel, Dist)
                    for i = 1, #data.Corners do
                        Functions:FadeOutOnDist(data.Corners[i], Dist)
                    end
                end

                local states = {}
                if data.IsNPC then
                    if char:GetAttribute("aim") then table.insert(states, "Aiming") end
                    if char:GetAttribute("isCrouch") then table.insert(states, "Crouching") end
                    if char:GetAttribute("isProne") then table.insert(states, "Proning") end
                    if char:GetAttribute("reload") then table.insert(states, "Reloading") end
                    if char:GetAttribute("run") then table.insert(states, "Sprinting") end
                    if char:GetAttribute("onFight") then table.insert(states, "Angry") end
                else
                    if char:GetAttribute("aim") then table.insert(states, "Aiming") end
                    if char:GetAttribute("crouch") then table.insert(states, "Crouching") end
                    if char:GetAttribute("prone") then table.insert(states, "Proning") end

                    local stateType = Humanoid:GetState()
                    if stateType == Enum.HumanoidStateType.Jumping or stateType == Enum.HumanoidStateType.Freefall then
                        table.insert(states, "Jumping")
                    end

                    local velocity = HRP.AssemblyLinearVelocity
                    local speed = velocity and velocity.Magnitude or 0
                    local moveDirection = Humanoid.MoveDirection.Magnitude
                    if speed > 16 then
                        table.insert(states, "Sprinting")
                    elseif moveDirection > 0.1 then
                        table.insert(states, "Walking")
                    end
                end

                if char:GetAttribute("peeking") then
                    if char:GetAttribute("peekingSide") == 1 then
                        table.insert(states, "Leaning Right")
                    else
                        table.insert(states, "Leaning Left")
                    end
                end

                if #states == 0 then
                    table.insert(states, "Idle")
                end

                local topOffset = 0
                local suffix = data.IsNPC and " [Npc]" or " [Player]"

                if ESP.Drawing.Names.Enabled then
                    data.Name.Visible = true
                    data.Name.TextColor3 = overrideNameColor or ESP.Drawing.Names.RGB
                    data.Name.Text = char.Name .. suffix
                    data.Name.Position = UDim2.new(0, midX, 0, midY - h / 2 - 12 - topOffset)
                    topOffset = topOffset + 14
                else
                    data.Name.Visible = false
                end

                if ESP.Drawing.Weapons.Enabled then
                    data.Weapon.Visible = true
                    data.Weapon.TextColor3 = ESP.Drawing.Weapons.WeaponTextRGB
                    local tool = char:FindFirstChildOfClass("Tool")
                    data.Weapon.Text = tool and cleanWeaponName(tool.Name) or "none"
                    data.Weapon.Position = UDim2.new(0, midX, 0, midY + h / 2 + 10)
                else
                    data.Weapon.Visible = false
                end

                if ESP.Drawing.Distances.Enabled then
                    data.Distance.Visible = true
                    data.Distance.TextColor3 = ESP.Drawing.Distances.RGB
                    data.Distance.Text = string.format("%dm", math.floor(Dist))
                    data.Distance.Position = UDim2.new(0, midX, 0, midY + h / 2 + 22)
                else
                    data.Distance.Visible = false
                end

                if ESP.Drawing.States.Enabled and #states > 0 then
                    local formattedStates = {}
                    for i = 1, #states do
                        local stateName = states[i]
                        local col = stateColorMap[stateName] or Color3.fromRGB(255, 255, 255)
                        local hex = string.format("#%02X%02X%02X", math.floor(col.R * 255), math.floor(col.G * 255), math.floor(col.B * 255))
                        table.insert(formattedStates, string.format('<font color="%s">(%s)</font>', hex, stateName))
                    end
                    data.StateLabel.Text = table.concat(formattedStates, " ")
                    data.StateLabel.Visible = true
                    data.StateLabel.Position = UDim2.new(0, midX + w / 2 + 8, 0, midY - h / 2)
                else
                    data.StateLabel.Visible = false
                end

                data.Chams.Adornee = char
                data.Chams.Enabled = ESP.Drawing.Chams.Enabled
                data.Chams.FillColor = ESP.Drawing.Chams.FillRGB
                data.Chams.OutlineColor = ESP.Drawing.Chams.OutlineRGB
                if ESP.Drawing.Chams.Thermal then
                    local breathe_effect = math.atan(math.sin(tick() * 2)) * 2 / math.pi
                    data.Chams.FillTransparency = ESP.Drawing.Chams.Fill_Transparency * breathe_effect * 0.01
                    data.Chams.OutlineTransparency = ESP.Drawing.Chams.Outline_Transparency * breathe_effect * 0.01
                else
                    data.Chams.FillTransparency = ESP.Drawing.Chams.Fill_Transparency * 0.01
                    data.Chams.OutlineTransparency = ESP.Drawing.Chams.Outline_Transparency * 0.01
                end
                data.Chams.DepthMode = ESP.Drawing.Chams.VisibleCheck and Enum.HighlightDepthMode.Occluded or Enum.HighlightDepthMode.AlwaysOnTop

                local cLen = math.clamp(w / 4, 5, 18)
                local t = ESP.Drawing.Corner.Thickness
                local cornerColor = ESP.Drawing.Corner.Color
                local cornerTrans = ESP.Drawing.Corner.Transparency
                local cornerEnabled = ESP.Drawing.Corner.Enabled

                for i = 1, #data.Corners do
                    data.Corners[i].Visible = cornerEnabled
                    data.Corners[i].BackgroundColor3 = cornerColor
                    data.Corners[i].BackgroundTransparency = cornerTrans
                end

                if cornerEnabled then
                    data.Corners[1].Position = UDim2.new(0, midX - w / 2, 0, midY - h / 2)
                    data.Corners[1].Size = UDim2.new(0, cLen, 0, t)
                    
                    data.Corners[2].Position = UDim2.new(0, midX - w / 2, 0, midY - h / 2)
                    data.Corners[2].Size = UDim2.new(0, t, 0, cLen)
                    
                    data.Corners[3].Position = UDim2.new(0, midX - w / 2, 0, midY + h / 2 - t)
                    data.Corners[3].Size = UDim2.new(0, cLen, 0, t)
                    
                    data.Corners[4].Position = UDim2.new(0, midX - w / 2, 0, midY + h / 2 - cLen)
                    data.Corners[4].Size = UDim2.new(0, t, 0, cLen)
                    
                    data.Corners[5].Position = UDim2.new(0, midX + w / 2 - cLen, 0, midY - h / 2)
                    data.Corners[5].Size = UDim2.new(0, cLen, 0, t)
                    
                    data.Corners[6].Position = UDim2.new(0, midX + w / 2 - t, 0, midY - h / 2)
                    data.Corners[6].Size = UDim2.new(0, t, 0, cLen)
                    
                    data.Corners[7].Position = UDim2.new(0, midX + w / 2 - cLen, 0, midY + h / 2 - t)
                    data.Corners[7].Size = UDim2.new(0, cLen, 0, t)
                    
                    data.Corners[8].Position = UDim2.new(0, midX + w / 2 - t, 0, midY + h / 2 - cLen)
                    data.Corners[8].Size = UDim2.new(0, t, 0, cLen)
                end

                data.Box.Position = UDim2.new(0, midX - w / 2, 0, midY - h / 2)
                data.Box.Size = UDim2.new(0, w, 0, h)
                data.Box.Visible = ESP.Drawing.Box.Enabled

                if ESP.Drawing.Filled.Enabled then
                    data.Box.BackgroundColor3 = ESP.Drawing.Filled.Color
                    data.Box.BackgroundTransparency = ESP.Drawing.Filled.Transparency
                else
                    data.Box.BackgroundTransparency = 1
                end

                if ESP.Drawing.Box.Animate or ESP.Drawing.Filled.Animate then
                    RotationAngle = RotationAngle + (tick() - Tick) * ESP.Drawing.Box.RotationSpeed * math.cos(math.pi / 4 * tick() - math.pi / 2)
                    data.OutlineGradient.Rotation = ESP.Drawing.Box.Animate and RotationAngle or -45
                    data.FillGradient.Rotation = ESP.Drawing.Filled.Animate and RotationAngle or -45
                else
                    data.OutlineGradient.Rotation = -45
                    data.FillGradient.Rotation = -45
                end
                Tick = tick()

                local health = math.clamp(Humanoid.Health / Humanoid.MaxHealth, 0, 1)
                local hbarXOffset = ESP.Layout.HealthbarSide == "Right" and (w / 2 + 4) or (-w / 2 - 4 - ESP.Drawing.Healthbar.Width)

                data.BehindHealthbar.Visible = ESP.Drawing.Healthbar.Enabled
                data.BehindHealthbar.Position = UDim2.new(0, midX + hbarXOffset, 0, midY - h / 2)
                data.BehindHealthbar.Size = UDim2.new(0, ESP.Drawing.Healthbar.Width, 0, h)

                data.HealthContainer.Visible = ESP.Drawing.Healthbar.Enabled
                data.HealthContainer.Position = UDim2.new(0, midX + hbarXOffset, 0, midY - h / 2 + h * (1 - health))
                data.HealthContainer.Size = UDim2.new(0, ESP.Drawing.Healthbar.Width, 0, h * health)

                data.Healthbar.Size = UDim2.new(0, ESP.Drawing.Healthbar.Width, 0, h)
                data.Healthbar.Position = UDim2.new(0, 0, 0, -h * (1 - health))

                data.HealthbarGradient.Enabled = ESP.Drawing.Healthbar.Gradient

                if ESP.Drawing.Healthbar.HealthText then
                    local healthPercentage = math.floor(health * 100)
                    data.HealthText.Position = UDim2.new(0, midX + hbarXOffset, 0, midY - h / 2 + h * (1 - health) + 3)
                    data.HealthText.Text = tostring(healthPercentage)
                    data.HealthText.Visible = true
                    if ESP.Drawing.Healthbar.Lerp then
                        data.HealthText.TextColor3 = health >= 0.75 and Color3.fromRGB(0, 255, 0) or health >= 0.5 and Color3.fromRGB(255, 255, 0) or health >= 0.25 and Color3.fromRGB(255, 170, 0) or Color3.fromRGB(255, 0, 0)
                    else
                        data.HealthText.TextColor3 = ESP.Drawing.Healthbar.HealthTextRGB
                    end
                else
                    data.HealthText.Visible = false
                end
            else
                data.MainFrame.Visible = false
                data.Chams.Enabled = false
            end
        else
            data.MainFrame.Visible = false
            data.Chams.Enabled = false
        end
    end
end)

local function scanContainer()
    for _, child in pairs(npcContainer:GetChildren()) do
        if child:IsA("Model") and child.Name ~= lplayer.Name then
            applyESP(child)
        end
    end
end

task.spawn(function()
    while true do
        scanContainer()
        task.wait(1)
    end
end)

npcContainer.ChildAdded:Connect(function(child)
    if child:IsA("Model") and child.Name ~= lplayer.Name then
        applyESP(child)
    end
end)

npcContainer.ChildRemoved:Connect(function(child)
    removeESP(child)
end)

return ESP
